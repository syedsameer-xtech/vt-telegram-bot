# =============================================================================
# VirusTotal Telegram Bot - Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --------------------------
# VirusTotal API
# --------------------------
# Get your API key from: https://www.virustotal.com/gui/my-apikey
VT_API_KEY=your_64_character_virustotal_api_key_here

# --------------------------
# Telegram Bot (from my.telegram.org)
# --------------------------
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_32_character_api_hash_here
TELEGRAM_TOKEN=your_bot_token_from_botfather_here

# --------------------------
# Bot Settings (Optional)
# --------------------------
MAX_FILE_SIZE_MB=32
ALLOWED_USER_IDS=           # Leave empty for all users, or add: 123456789,987654321
RATE_LIMIT_PER_USER=10

# --------------------------
# Paths (Optional - defaults shown)
# --------------------------
# DB_PATH=~/.virustotal_bot/scans.db
# LOG_PATH=~/.virustotal_bot/bot.log
# TEMP_DIR=~/.virustotal_bot/temp
